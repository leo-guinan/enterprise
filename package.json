{
  "name": "enterprise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run ui\"",
    "ui": "vite",
    "server": "tsx server/index.ts",
    "daemon": "node daemon/poll.mjs",
    "daemon:loop": "node daemon/poll.mjs --loop --interval=5 --pyramid-interval=600",
    "pyramid": "node daemon/pyramid-sync.mjs",
    "pyramid:loop": "node daemon/pyramid-sync.mjs --loop --interval=300",
    "pyramid:load": "node daemon/pyramid-load.mjs",
    "build": "vite build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@tanstack/react-query": "^5.60.0",
    "sql.js": "^1.11.0",
    "concurrently": "^9.1.0",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
